# .env.example — Copier en .env et adapter
# Ne jamais committer .env dans git

# ── API ──────────────────────────────────────────────────────────────────────
API_KEY=urban-explorer-dev-key
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ── PostgreSQL + PostGIS (C1.1 — relationnel) ────────────────────────────────
# Hors Docker : localhost:5433 (le 5432 hôte est laissé libre pour un Postgres
# local éventuel). Sous docker compose : hostname "postgres", port 5432.
POSTGRES_URI=postgresql+psycopg2://urban:urban_dev_pwd@localhost:5433/urban_data

# ── MongoDB (C1.2 — NoSQL) ───────────────────────────────────────────────────
# Hors Docker : localhost. Sous docker compose, le hostname est "mongo".
MONGO_URI=mongodb://urban:urban_dev_pwd@localhost:27017/urban_data?authSource=admin
MONGO_DB_NAME=urban_data
